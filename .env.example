# Database
DATABASE_URL="postgresql://platform_user:platform_pass@localhost:5432/financial_platform"

# Auth - generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_THIS_TO_RANDOM_SECRET_MIN_32_CHARS"
JWT_EXPIRY="8h"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="منصة إدارة الحركة المالية"

# Upload limits
MAX_FILE_SIZE_MB=50

# Session
SESSION_TIMEOUT_MINUTES=30
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=30
